generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          String   @id
  externalId  Int
  competition String   @default("PL")
  season      Int      @default(2026)
  name        String
  shortName   String
  tla         String
  crestUrl    String
  venue       String?
  updatedAt   DateTime @updatedAt

  @@unique([externalId, competition, season])
  @@map("teams")
}

model Matchweek {
  id          String   @id
  number      Int
  competition String   @default("PL")
  season      Int      @default(2026)
  label       String?
  startDate   DateTime
  endDate     DateTime
  status      String
  matches     Match[]

  @@unique([competition, season, number])
  @@map("matchweeks")
}

model Match {
  id          String    @id
  externalId  Int       @unique
  matchweekId String
  matchweek   Matchweek @relation(fields: [matchweekId], references: [id], onDelete: Cascade)
  homeTeamId  String
  awayTeamId  String
  kickoff     DateTime
  homeScore   Int?
  awayScore   Int?
  status      String
  venue       String?
  stage       String?
  predictions Prediction[]

  @@index([matchweekId])
  @@map("matches")
}

model Prediction {
  id        String   @id
  userId    String
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeScore Int
  awayScore Int
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
  @@map("predictions")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  isAdmin        Boolean   @default(false)
  profilePicture String?
  supportedTeam  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AppSettings {
  id                String   @id @default("default")
  registrationOpen  Boolean  @default(true)
  maxUsers          Int      @default(60)
  updatedAt         DateTime @updatedAt

  @@map("app_settings")
}

model MatchPointerSelection {
  id               String   @id @default(cuid())
  userId           String
  matchId          String
  selectedPointers String[]
  details          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
  @@map("match_pointer_selections")
}

model PrivateLeague {
  id           String                     @id @default(cuid())
  name         String
  slug         String                     @unique
  inviteCode   String                     @unique
  createdById  String
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  members      PrivateLeagueMember[]
  competitions PrivateLeagueCompetition[]

  @@index([createdById])
  @@map("private_leagues")
}

model PrivateLeagueMember {
  id       String        @id @default(cuid())
  leagueId String
  league   PrivateLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId   String
  role     String        @default("member")
  joinedAt DateTime      @default(now())

  @@unique([leagueId, userId])
  @@index([userId])
  @@map("private_league_members")
}

model PrivateLeagueCompetition {
  id          String        @id @default(cuid())
  leagueId    String
  league      PrivateLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  competition String
  season      Int           @default(2026)

  @@unique([leagueId, competition, season])
  @@map("private_league_competitions")
}
